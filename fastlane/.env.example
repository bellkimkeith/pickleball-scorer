# Copy this file to fastlane/.env and fill in your real values.
# fastlane/.env is git-ignored and must NEVER be committed.
#
# Fastlane auto-loads fastlane/.env at startup (no extra setup needed).

# ── App Store Connect API Key ──────────────────────────────────────────────────
# From: appstoreconnect.apple.com → Users and Access → Integrations → API Keys
ASC_KEY_ID=
ASC_ISSUER_ID=
# Absolute path to the downloaded .p8 file (e.g. ~/secrets/AuthKey_XXXXXXXX.p8)
ASC_KEY_FILEPATH=

# ── Apple Developer Account ────────────────────────────────────────────────────
# Your Apple ID email used to log in to developer.apple.com
APPLE_ID=
# From: developer.apple.com → Account → Membership Details
APPLE_TEAM_ID=

# ── Fastlane Match (cert storage) ─────────────────────────────────────────────
# HTTPS URL of your private GitHub repo for storing encrypted certs
MATCH_GIT_URL=https://github.com/YOUR_USERNAME/pickleball-certs.git
# Password used to encrypt/decrypt certs in the repo (choose a strong one)
MATCH_PASSWORD=
# base64("YOUR_GITHUB_USERNAME:YOUR_GITHUB_PERSONAL_ACCESS_TOKEN")
# Run: echo -n "username:token" | base64
MATCH_GIT_BASIC_AUTHORIZATION=

# ── Build ──────────────────────────────────────────────────────────────────────
# Build number for local runs (Jenkins overrides this automatically)
BUILD_NUMBER=1
