default_platform(:ios)

platform :ios do

  # ── Build for simulator (no signing needed) ──
  # Use this to test the pipeline without an Apple Developer account
  desc "Build the iOS app for simulator (no signing needed)"
  lane :build_sim do
    # Note: pod install is handled by `expo prebuild --clean` in the Jenkins pipeline.
    # If running fastlane locally, run `npx expo prebuild` first.

    # Use xcodebuild directly for simulator builds
    # gym/build_app is designed for device archives, not simulator .app output
    sh(
      "xcodebuild " \
      "-workspace ../ios/PickleScore.xcworkspace " \
      "-scheme PickleScore " \
      "-configuration Release " \
      "-sdk iphonesimulator " \
      "-derivedDataPath ../build/derived_data " \
      "CODE_SIGNING_ALLOWED=NO " \
      "build"
    )

    # Copy the .app and zip it with build number for easy download
    build_num = ENV["BUILD_NUMBER"] || "local"
    zip_name = "PickleScore-dev-#{build_num}.zip"

    sh("mkdir -p ../build/simulator")
    sh("cp -R ../build/derived_data/Build/Products/Release-iphonesimulator/PickleScore.app ../build/simulator/")
    sh("cd ../build/simulator && zip -r ../#{zip_name} PickleScore.app")
  end

  # ── Build signed .ipa (requires Apple Developer account) ──
  desc "Build signed .ipa for distribution"
  lane :build do
    # Note: pod install is handled by `expo prebuild --clean` in the Jenkins pipeline.
    # If running fastlane locally, run `npx expo prebuild` first.

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_FILEPATH"]
    )

    match(
      type: "appstore",
      api_key: api_key,
      readonly: true # CI always reads, never writes new certs
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: ENV["APPLE_TEAM_ID"],
      path: "./ios/PickleScore.xcodeproj",
      targets: ["PickleScore"]
    )

    increment_build_number(
      xcodeproj: "./ios/PickleScore.xcodeproj",
      build_number: ENV["BUILD_NUMBER"] || "1"
    )

    build_app(
      workspace: "./ios/PickleScore.xcworkspace",
      scheme: "PickleScore",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build/ios",
      output_name: "PickleScore.ipa",
      clean: true,
      xcargs: "DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']} CODE_SIGN_STYLE=Manual",
      export_options: {
        method: "app-store",
        teamID: ENV["APPLE_TEAM_ID"],
        provisioningProfiles: {
          "com.bellkimkeith.pickleballscorer" => "match AppStore com.bellkimkeith.pickleballscorer"
        }
      }
    )
  end

  # ── Upload to TestFlight ──
  desc "Build and upload to TestFlight"
  lane :beta do
    build

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_FILEPATH"]
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      api_key: api_key
    )
  end

  # ── Upload to App Store (no auto-submit — you manually submit for review) ──
  desc "Build and upload to App Store Connect"
  lane :release do
    build

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_FILEPATH"]
    )

    upload_to_app_store(
      skip_screenshots: true,
      skip_metadata: true,
      submit_for_review: false, # You manually submit for review from App Store Connect
      api_key: api_key
    )
  end

  error do |lane, exception|
    UI.error("Lane #{lane} failed: #{exception.message}")
  end
end

